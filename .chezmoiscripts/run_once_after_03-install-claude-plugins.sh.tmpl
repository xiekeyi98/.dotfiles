#!/bin/bash
{{ if and (lookPath "claude") .installClaudeCode -}}
echo "==> Installing Claude Code plugins..."

# Add marketplaces
claude plugin marketplace add superpowers-marketplace --source github --repo obra/superpowers-marketplace 2>/dev/null || true
claude plugin marketplace add wakatime --source git --url https://github.com/wakatime/claude-code-wakatime.git 2>/dev/null || true

# Update marketplace cache
claude plugin marketplace update 2>/dev/null || true

# Install enabled plugins
{{ range list "superpowers@superpowers-marketplace" "skill-creator@claude-plugins-official" "hookify@claude-plugins-official" "feature-dev@claude-plugins-official" "claude-code-wakatime@wakatime" "pr-review-toolkit@claude-plugins-official" "security-guidance@claude-plugins-official" -}}
if ! claude plugin list 2>/dev/null | grep -q "{{ . }}"; then
    echo "  [install] {{ . }}"
    claude plugin install "{{ . }}" 2>/dev/null || echo "  [warn] failed to install {{ . }}"
else
    echo "  [ok] {{ . }} already installed"
fi
{{ end -}}
{{ end -}}
